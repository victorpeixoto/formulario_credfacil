# Copie para .env.local e preencha as credenciais reais
# Para testar o fluxo básico (formulário + auth + MongoDB), só MONGODB_URI e JWT_SECRET são obrigatórios

# MongoDB — aponta para o container Docker local
MONGODB_URI=mongodb://localhost:27017/credfacil

# JWT — qualquer string longa serve para dev
JWT_SECRET=dev-secret-mude-em-producao-123456

# Cloudflare R2 — necessário para upload de documentos
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=credfacil-documentos

# Google Gemini — necessário para validação IA
GEMINI_API_KEY=

# AWS Rekognition — necessário para biometria
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Email (recuperação de senha)
EMAIL_FROM=noreply@credfacil.com.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Telegram (alertas internos)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Chatwoot + WhatsApp (rodízio de números)
CHATWOOT_API_URL=
CHATWOOT_API_TOKEN=

# Meta CAPI (pixel de conversão)
META_PIXEL_ID=
META_CAPI_TOKEN=

# URL base para links no email
NEXT_PUBLIC_BASE_URL=http://localhost:3000
