# =============================================================================
# OBRIGATÓRIO — fluxo básico (formulário + autenticação)
# =============================================================================

# Conexão com o banco de dados MongoDB
# Local (Docker): mongodb://localhost:27017/credfacil
# Produção: mongodb+srv://user:pass@cluster.mongodb.net/credfacil
MONGODB_URI=

# Segredo para assinar os tokens JWT (qualquer string longa e aleatória)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# =============================================================================
# CLOUDFLARE R2 — upload de documentos
# Necessário para: /documentos (upload dos 5 arquivos)
# =============================================================================

# ID da sua conta Cloudflare (dashboard.cloudflare.com → lado direito)
R2_ACCOUNT_ID=

# Chave de acesso gerada em: R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nome do bucket R2 criado para o projeto
R2_BUCKET_NAME=credfacil-documentos

# =============================================================================
# GOOGLE GEMINI — validação de documentos via IA (OCR + vídeo)
# Necessário para: CNH, comprovante, selfie, vídeo app, vídeo veículo
# =============================================================================

# Chave de API obtida em: aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =============================================================================
# AWS REKOGNITION — comparação facial (biometria)
# Necessário para: validarBiometria (CNH vs selfie)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# EMAIL SMTP — recuperação de senha
# Necessário para: /api/auth/recuperar (envio do link de redefinição)
# =============================================================================

# Endereço remetente exibido no email
EMAIL_FROM=noreply@seudominio.com.br

# Configurações do servidor SMTP
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =============================================================================
# TELEGRAM — alertas internos
# Necessário para: alerta de 3+ tentativas e falha de WhatsApp
# =============================================================================

# Token do bot obtido via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# ID do chat/grupo que receberá os alertas
TELEGRAM_CHAT_ID=

# =============================================================================
# CHATWOOT — rodízio de números WhatsApp
# Necessário para: botão WhatsApp após aprovação dos documentos
# =============================================================================

# URL da API de inboxes do Chatwoot (ex: https://app.chatwoot.com/auth/sign_in)
CHATWOOT_API_URL=
CHATWOOT_API_TOKEN=

# =============================================================================
# META / FACEBOOK — pixel de conversão (CAPI)
# Necessário para: eventos CompleteRegistration e Purchase
# =============================================================================

META_PIXEL_ID=
META_ACCESS_TOKEN=

# =============================================================================
# APP — configuração geral
# =============================================================================

# URL base da aplicação (sem barra final)
# Local: http://localhost:3000
# Produção: https://formulario.seudominio.com.br
NEXT_PUBLIC_BASE_URL=http://localhost:3000
